# =============================================
# Production - HTTPS + Public Domain
# Load with: bun --env-file=.env.base --env-file=.env.prod-domain ...
# =============================================

# Network configuration
FRONTEND_HOST="https://next.yourcompany.com"
SERVER_HOST="https://nest.yourcompany.com"
CORS_ORIGINS="https://next.yourcompany.com"
NEXT_PUBLIC_NESTJS="https://nest.yourcompany.com"

# Medusa
MEDUSA_BACKEND_URL="https://medusa.yourcompany.com"
NEXT_PUBLIC_MEDUSA_BACKEND_URL="https://medusa.yourcompany.com"
STORE_CORS="https://next.yourcompany.com"
ADMIN_CORS="https://medusa.yourcompany.com,https://next.yourcompany.com"
AUTH_CORS="https://medusa.yourcompany.com,https://next.yourcompany.com"
PAYPAL_RETURN_URL="https://next.yourcompany.com/medusa/store-api/payment/return"
PAYPAL_CANCEL_URL="https://next.yourcompany.com/medusa/store-api/payment/cancel"

# Cookie settings - adjust based on your domain structure
COOKIE_DOMAIN=".yourcompany.com"
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE="none"

ENV="PROD"
