{
  "name": "nest-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "# Production builds": "",
    "build:prod-domain": "bun --env-file=../../.env.base --env-file=../../.env.prod-domain run build",
    "build:prod-ip": "bun --env-file=../../.env.base --env-file=../../.env.prod-ip run build",
    "format": "biome --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "# Dev with domain (HTTPS)": "",
    "dev:domain": "bun --env-file=../../.env.base --env-file=../../.env.dev-domain run dev",
    "# Dev with internal IP (HTTP)": "",
    "dev:ip": "bun --env-file=../../.env.base --env-file=../../.env.prod-ip run dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "# Production start (after build)": "",
    "start:prod-domain": "bun --env-file=../../.env.base --env-file=../../.env.prod-domain run start:prod",
    "start:prod-ip": "bun --env-file=../../.env.base --env-file=../../.env.prod-ip run start:prod",
    "lint": "biome lint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@casl/ability": "^6.7.3",
    "@cerbos/core": "^0.25.2",
    "@cerbos/grpc": "^0.23.5",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/websockets": "^11.1.9",
    "@repo/database": "workspace:*",
    "@repo/types": "workspace:*",
    "ali-oss": "^6.23.0",
    "archiver": "^8.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.65.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dayjs": "^1.11.19",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "exceljs-ext": "^0.1.3",
    "ioredis": "^5.8.2",
    "multer": "^2.2.0",
    "nanoid": "5",
    "pako": "^2.1.0",
    "pdfkit": "^0.19.1",
    "piscina": "^5.2.0",
    "qcloud-cos-sts": "^3.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.5.2",
    "rxjs": "^7.8.2",
    "turbo": "^2.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/ali-oss": "^6.23.3",
    "@types/archiver": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "24.10.1",
    "@types/pako": "^2.0.4",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.3",
    "jest": "30.2.0",
    "socket.io": "^4.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
