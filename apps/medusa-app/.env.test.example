# Copy to .env.test and fill in. Do not commit real secrets.
# Same file for `bun run test:dev`, `test:db:prepare`, and `test:integration:bun` (--env-file).

NODE_ENV="test"

MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=https://next.sandbox.local
ADMIN_CORS=https://medusa.sandbox.local,https://next.sandbox.local
AUTH_CORS=https://medusa.sandbox.local,https://next.sandbox.local
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
JWT_EXPIRES_IN=1d
COOKIE_SECRET=supersecret
COOKIE_DOMAIN=localhost
# must use port 9000, a bug in medusa forces admin dashboard to use this port when loading product thumbnails
PORT=9000
LOG_FILE=.log/all.log

DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
DATABASE_NAME=medusa-backend-sandbox-test
DATABASE_URL=postgres://$DATABASE_USER:$DATABASE_PASSWORD@localhost:5432/$DATABASE_NAME
DATABASE_URL_MAINTENANCE=postgres://$DATABASE_USER:$DATABASE_PASSWORD@localhost:5432/postgres

USER_ACCOUNT=admin@test.local
CUSTOMER_ACCOUNT=customer@test.local
PASSWORD=change-me

MEDUSA_BACKEND_URL=http://127.0.0.1:9000

# Resend
RESEND_API_KEY="re_******"
RESEND_SENDER_NAME="MEDUSA"
RESEND_SENDER_EMAIL="send@example.com"

# PayPal Payment Module
PAYPAL_CLIENT_ID="Your PayPal Client ID"
PAYPAL_CLIENT_SECRET="Your PayPal Client Secret"
PAYPAL_RETURN_URL="https://next.sandbox.local/medusa/store-api/payment/return"
PAYPAL_CANCEL_URL="https://next.sandbox.local/medusa/store-api/payment/cancel"
PAYPAL_WEBHOOK_ID="Your PayPal Webhook ID"

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=change-me-meilisearch-master-key
MEILISEARCH_PRODUCT_INDEX_NAME=test
