# Copy to .env.test and fill in. Do not commit real secrets.

# --- Test Postgres (used by test:db:prepare; override DATABASE_URL when starting Medusa for E2E) ---
DATABASE_URL_TEST=postgres://postgres:password@localhost:5432/medusa-backend-sandbox-test
# DATABASE_URL_TEST_MAINTENANCE=postgres://postgres:password@localhost:5432/postgres

# --- Bootstrap accounts (dev only; shared PASSWORD when creating if missing) ---
USER_ACCOUNT=admin@test.local
CUSTOMER_ACCOUNT=customer@test.local
PASSWORD=change-me

# --- Bun HTTP E2E client ---
TEST_HTTP_BASE_URL=http://127.0.0.1:9000
TEST_PUBLISHABLE_API_KEY=pk_replace_after_seed
TEST_REGION_ID=reg_replace_after_seed
TEST_SALES_CHANNEL_ID=
TEST_VARIANT_ID=
TEST_CUSTOMER_EMAIL=customer@test.local
TEST_CUSTOMER_PASSWORD=change-me
