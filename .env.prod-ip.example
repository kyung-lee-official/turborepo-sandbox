# =============================================
# Local IP Mode - Internal Network (HTTP + IP only, no domain)
# Load with: bun --env-file=.env.base --env-file=.env.prod-ip ...
# =============================================

# Network configuration (next-app runs on port 4000, nest-app on 3001)
FRONTEND_HOST="http://localhost:4000"
SERVER_HOST="http://localhost:3001"
CORS_ORIGINS="http://localhost:4000,http://127.0.0.1:4000"
NEXT_PUBLIC_NESTJS="http://localhost:3001"

# Medusa
MEDUSA_BACKEND_URL="http://localhost:9000"
NEXT_PUBLIC_MEDUSA_BACKEND_URL="http://localhost:9000"
STORE_CORS="http://localhost:4000"
ADMIN_CORS="http://localhost:9000,http://localhost:4000"
AUTH_CORS="http://localhost:9000,http://localhost:4000"
PAYPAL_RETURN_URL="http://localhost:4000/medusa/store-api/payment/return"
PAYPAL_CANCEL_URL="http://localhost:4000/medusa/store-api/payment/cancel"

# No domain for IP-only deployment → host-only cookies
COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE="lax"

ENV="PROD"
