# =============================================
# Development - HTTPS + Custom Domain (sandbox.local)
# Load with: bun --env-file=.env.base --env-file=.env.dev-domain ...
# =============================================

# Network configuration
FRONTEND_HOST="https://next.sandbox.local"
SERVER_HOST="https://nest.sandbox.local"
CORS_ORIGINS="https://next.sandbox.local"
NEXT_PUBLIC_NESTJS="https://nest.sandbox.local"

# Medusa
MEDUSA_BACKEND_URL="https://medusa.sandbox.local"
NEXT_PUBLIC_MEDUSA_BACKEND_URL="https://medusa.sandbox.local"
STORE_CORS="https://next.sandbox.local"
ADMIN_CORS="https://medusa.sandbox.local,https://next.sandbox.local"
AUTH_CORS="https://medusa.sandbox.local,https://next.sandbox.local"
PAYPAL_RETURN_URL="https://next.sandbox.local/medusa/store-api/payment/return"
PAYPAL_CANCEL_URL="https://next.sandbox.local/medusa/store-api/payment/cancel"

# Cookie settings for cross-subdomain HTTPS (if used)
COOKIE_DOMAIN=".sandbox.local"
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE="none"

ENV="DEV"
