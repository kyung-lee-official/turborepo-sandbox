# =============================================
# BASE CONFIGURATION - Shared across all environments
# Copy to .env.base and fill in real values.
# Load with: bun --env-file=.env.base --env-file=.env.<mode> ...
# =============================================

# Environment
ENV="DEV"

# Optional dev tunnels (set to 1 or true to include in `turbo run dev`)
ENABLE_BORE=false

# JWT (Nest: apps/nest-app)
SECRET=your-super-secret-jwt-key-here-change-in-production

# =============================================
# DATABASE
# =============================================

DATABASE_URL="postgresql://user:password@localhost:5432/turborepo-sandbox-db?schema=public"

# Cerbos PDP (Authorization)
CERBOS="localhost:3592"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================
# 3RD PARTY SERVICES (Nest)
# =============================================

# Resend (Email delivery)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Object Storage (Tencent COS)
SECRET_ID=your-secret-id
SECRET_KEY=your-secret-key
BUCKET=your-bucket-name
REGION=ap-guangzhou

# =============================================
# 3RD PARTY SERVICES (Next.js)
# =============================================

# Tencent COS (client-side uploads)
NEXT_PUBLIC_BUCKET=your-bucket-name
NEXT_PUBLIC_REGION=ap-guangzhou

# Aliyun OSS
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_SECRET=
ALIYUN_OSS_REGION=oss-us-west-1
ALIYUN_OSS_BUCKET=

# Google OAuth 2.0
GOOGLE_OAUTH20_SERVER_HOST="http://localhost:3001"
GOOGLE_OAUTH20_CLIENT_ID=
GOOGLE_OAUTH20_VANILLA_REDIRECT_URI="http://localhost:3001/google-oauth2/vanilla"

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# PayPal
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID="Your PayPal Client ID"
PAYPAL_CLIENT_SECRET="Your PayPal Client Secret"
PAYPAL_WEBHOOK_ID="Your PayPal Webhook ID"

# Orama
NEXT_PUBLIC_ORAMA_ENDPOINT=
NEXT_PUBLIC_ORAMA_API_KEY=

# Medusa (apps/medusa-app)
NODE_ENV="development"
MEDUSA_ADMIN_ONBOARDING_TYPE=default
MEDUSA_DATABASE_URL="postgresql://user:password@localhost:5432/medusa-sandbox"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="supersecret"
JWT_EXPIRES_IN="1d"
COOKIE_SECRET="supersecret"
PORT=9000
LOG_FILE=".log/all.log"
RESEND_SENDER_NAME="MEDUSA"
RESEND_SENDER_EMAIL="send@medusa.com"
OCEANPAYMENT_ACCOUNT="Your Oceanpayment account number"
OCEANPAYMENT_TERMINAL="Your Oceanpayment terminal number"
OCEANPAYMENT_SECURE_CODE="Your Oceanpayment secureCode (signing)"
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="change-me-meilisearch-master-key"
MEILISEARCH_PRODUCT_INDEX_NAME="products"
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# =============================================
# NOTE: Network-specific variables (CORS, hosts, NEXT_PUBLIC_NESTJS, MEDUSA_BACKEND_URL, etc.)
# are defined in:
#   .env.dev-domain.example
#   .env.prod-domain.example
#   .env.prod-ip.example
# =============================================
