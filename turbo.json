{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": ["DATABASE_URL", "MEDUSA_DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**", "build/**", ".medusa/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "start:prod": {
      "cache": false,
      "persistent": true
    },
    "db:nest:generate": {
      "cache": true,
      "outputs": ["src/generated/**"]
    },
    "db:nest:migrate:dev": {
      "cache": false
    },
    "db:nest:migrate:deploy": {
      "cache": false
    },
    "db:nest:studio": {
      "cache": false,
      "persistent": true
    },
    "db:medusa:migrate": {
      "cache": false
    },
    "db:medusa:seed": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "medusa:next": {},
    "test:dev": {}
  }
}
